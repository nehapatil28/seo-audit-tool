# Copy this file to .env and fill in your own keys.
# Get a free PageSpeed key: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=

# Get a free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get a free Groq key: https://console.groq.com/keys
GROQ_API_KEY=

# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Used by the chatbot module (can reuse your GROQ_API_KEY)
GROQ_CHATBOT_KEY=

# Postgres connection string, e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=
